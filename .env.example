## Backend
PORT=4000
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────────────────────────
# LOCAL (with Docker):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turf_booking
#
# FREE CLOUD (no Docker needed — just sign up):
#   Neon    → https://neon.tech    (recommended, fastest setup)
#   Supabase→ https://supabase.com
#   Railway → https://railway.app
#
# Paste your cloud connection string from one of the providers above:
DATABASE_URL=postgresql://user:password@host/dbname

JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

## Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
